{
    "model_name": "decalign",
    "use_bert": true,
    "use_finetune": true,
    "transformers": "bert",
    "pretrained": "bert-base-uncased",
    "need_data_aligned": true,
    "dst_feature_dim_nheads": [64, 8],
    "nlevels": 4,
    "conv1d_kernel_size_l": 5,
    "conv1d_kernel_size_a": 5,
    "conv1d_kernel_size_v": 5,
    "num_prototypes": 7,
    "gmm_em_iters": 5,
    "gmm_var_floor": 0.0001,
    "lambda_ot": 0.1,
    "ot_num_iters": 50,
    "use_cross_modal_attention": true,
    "pde_dim": 64,
    "mmd_bandwidth": 1.0,
    "attn_dropout": 0.2,
    "attn_dropout_a": 0.2,
    "attn_dropout_v": 0.2,
    "relu_dropout": 0.2,
    "embed_dropout": 0.2,
    "res_dropout": 0.2,
    "output_dropout": 0.2,
    "text_dropout": 0.2,
    "attn_mask": true,
    "task_loss": "mse",
    "loss_contract": "paper",
    "dec_loss_weight": 1.0,
    "alpha": 0.05,
    "beta": 0.05,
    "ct_weight": 0.01,
    "ct_temperature": 0.1,
    "batch_size": 32,
    "learning_rate": 0.0001,
    "weight_decay": 0.005,
    "num_epochs": 50,
    "patience": 5,
    "scheduler_patience": 5,
    "early_stop_patience": 12,
    "selection_metric": "F1_score",
    "scheduler_metric": "F1_score",
    "selection_mode": "max",
    "scheduler_mode": "max",
    "clip": 0.6,
    "when": 5,
    "factor": 0.1
}
