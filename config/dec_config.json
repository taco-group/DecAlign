{
    "model_name": "decalign",
    "use_bert": true,
    "use_finetune": true,
    "transformers": "bert",
    "pretrained": "bert-base-uncased",
    "need_data_aligned": true,
    "dst_feature_dim_nheads": [40, 10],
    "nlevels": 5,
    "conv1d_kernel_size_l": 1,
    "conv1d_kernel_size_a": 1,
    "conv1d_kernel_size_v": 1,
    "num_prototypes": 7,
    "gmm_em_iters": 5,
    "gmm_var_floor": 0.0001,
    "lambda_ot": 0.1,
    "ot_num_iters": 50,
    "use_cross_modal_attention": true,
    "pde_dim": 40,
    "mmd_bandwidth": 1.0,
    "attn_dropout": 0.1,
    "attn_dropout_a": 0.0,
    "attn_dropout_v": 0.0,
    "relu_dropout": 0.1,
    "embed_dropout": 0.25,
    "res_dropout": 0.1,
    "output_dropout": 0.0,
    "text_dropout": 0.0,
    "attn_mask": true,
    "task_loss": "mse",
    "dec_loss_weight": 1.0,
    "alpha": 0.1,
    "beta": 0.1,
    "ct_weight": 0.0,
    "ct_temperature": 0.1,
    "use_sequence_mask": false,
    "batch_size": 24,
    "learning_rate": 0.001,
    "weight_decay": 0.0,
    "num_epochs": 100,
    "patience": 20,
    "clip": 0.8,
    "when": 20,
    "factor": 0.1
}
