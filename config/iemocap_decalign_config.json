{
    "model_name": "decalign",
    "train_mode": "classification",
    "num_classes": 6,
    "use_bert": false,
    "use_finetune": false,
    "transformers": "bert",
    "pretrained": "bert-base-uncased",
    "need_data_aligned": true,
    "feature_dims": [1024, 512, 1024],
    "seq_lens": [1, 1, 1],
    "dst_feature_dim_nheads": [48, 4],
    "nlevels": 4,
    "conv1d_kernel_size_l": 1,
    "conv1d_kernel_size_a": 1,
    "conv1d_kernel_size_v": 1,
    "num_prototypes": 6,
    "gmm_em_iters": 5,
    "gmm_var_floor": 0.0001,
    "lambda_ot": 0.1,
    "ot_num_iters": 50,
    "use_cross_modal_attention": true,
    "pde_dim": 48,
    "mmd_bandwidth": 1.0,
    "attn_dropout": 0.2,
    "attn_dropout_a": 0.2,
    "attn_dropout_v": 0.2,
    "relu_dropout": 0.2,
    "embed_dropout": 0.2,
    "res_dropout": 0.2,
    "output_dropout": 0.2,
    "text_dropout": 0.2,
    "attn_mask": true,
    "loss_contract": "paper",
    "dec_loss_weight": 1.0,
    "alpha": 0.05,
    "beta": 0.05,
    "ct_weight": 0.0,
    "ct_temperature": 0.1,
    "class_weight": "none",
    "active_modalities": ["text", "audio", "vision"],
    "iemocap_protocol": "session_valid",
    "batch_size": 32,
    "learning_rate": 0.0001,
    "weight_decay": 0.005,
    "num_epochs": 50,
    "patience": 5,
    "scheduler_patience": 5,
    "early_stop_patience": 5,
    "selection_metric": "WAF1",
    "selection_mode": "max",
    "scheduler_metric": "WAF1",
    "scheduler_mode": "max",
    "clip": 0.6,
    "when": 5,
    "factor": 0.1
}
