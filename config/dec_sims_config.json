{
    "model_name": "decalign",
    "use_bert": true,
    "use_finetune": true,
    "transformers": "bert",
    "pretrained": "bert-base-chinese",
    "need_data_aligned": false,
    "dst_feature_dim_nheads": [32, 8],
    "nlevels": 4,
    "conv1d_kernel_size_l": 5,
    "conv1d_kernel_size_a": 5,
    "conv1d_kernel_size_v": 5,
    "num_prototypes": 7,
    "gmm_em_iters": 5,
    "gmm_var_floor": 0.0001,
    "lambda_ot": 0.1,
    "ot_num_iters": 50,
    "use_cross_modal_attention": true,
    "pde_dim": 32,
    "mmd_bandwidth": 1.0,
    "attn_dropout": 0.4,
    "attn_dropout_a": 0.3,
    "attn_dropout_v": 0.1,
    "relu_dropout": 0.1,
    "embed_dropout": 0.3,
    "res_dropout": 0.1,
    "output_dropout": 0.35,
    "text_dropout": 0.25,
    "attn_mask": true,
    "task_loss": "mse",
    "dec_loss_weight": 1.0,
    "alpha": 0.0175,
    "beta": 0.0525,
    "ct_weight": 0.01,
    "ct_temperature": 0.07,
    "binary_task_weight": 0.01,
    "use_sequence_mask": false,
    "batch_size": 24,
    "learning_rate": 0.000035,
    "bert_learning_rate": 0.0000075,
    "weight_decay": 0.005,
    "num_epochs": 55,
    "patience": 5,
    "scheduler_patience": 5,
    "early_stop_patience": 11,
    "selection_metric": "F1_score",
    "scheduler_metric": "F1_score",
    "selection_mode": "max",
    "scheduler_mode": "max",
    "need_feature_standardized": true,
    "feature_standardize_modalities": ["audio", "vision"],
    "feature_clip_percentiles": [0.1, 99.9],
    "clip": 0.5,
    "when": 5,
    "factor": 0.1
}
